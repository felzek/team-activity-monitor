PORT=3000
APP_NAME=Team Activity Monitor
APP_BASE_URL=http://localhost:3000
APP_TIMEZONE=America/New_York
APP_ENV=development
AWS_REGION=us-east-1
USE_RECORDED_FIXTURES=true
TEAM_MEMBERS_CONFIG=config/team-members.json
TRACKED_REPOS_CONFIG=config/repos.json
FIXTURE_DIR=fixtures/demo
DATABASE_PATH=data/app.db
SESSION_SECRET=change-me-in-production
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=120
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_EMAIL=your-email@example.com
JIRA_API_TOKEN=your-jira-api-token
JIRA_OAUTH_CLIENT_ID=
JIRA_OAUTH_CLIENT_SECRET=
JIRA_OAUTH_SCOPE=read:me read:jira-user offline_access
GITHUB_TOKEN=your-github-token
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_SCOPE=read:user user:email
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_SCOPE=openid email profile
OLLAMA_BASE_URL=http://localhost:11434/api
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_KEEP_ALIVE=10m
COGNITO_USER_POOL_ID=
COGNITO_APP_CLIENT_ID=
COGNITO_DOMAIN=
RESEND_API_KEY=
EMAIL_FROM=Team Activity <noreply@mail.yourdomain.com>
TAIGA_BASE_URL=
TAIGA_TOKEN=
TAIGA_USERNAME=
TAIGA_PASSWORD=
TAIGA_PROJECT_ID=
TAIGA_PROJECT_SLUG=
TAIGA_PROJECT_NAME=
TAIGA_PROJECT_DESCRIPTION=Backlog review project for the Team Activity Monitor MVP.
TAIGA_PROJECT_PRIVATE=true
TAIGA_BACKLOG_PATH=plan/backlog.json
TAIGA_REPORT_PATH=plan/taiga-import-report.json
